# =============================================================================
# N.O.V.A. — .gitignore
# Strategy: ignore tooling/runtime artifacts; keep planning + source in the tree.
# =============================================================================

# --- Python / uv (Story 1.1+ territory) -------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg-info/
*.egg

# --- Local SQLite / runtime data --------------------------------------------
# Runtime user data lives in %LOCALAPPDATA%/nova/, outside the tree.
# These patterns catch any local accident where a DB leaks into the repo.
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# --- IDE / editor ------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS cruft ----------------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store

# --- Local agent / tooling config (not project source) ----------------------
.claude/
.agents/

# --- BMad module install (regeneratable; outputs are kept) ------------------
_bmad/

# --- Logs --------------------------------------------------------------------
*.log
logs/

# --- Secrets (belt-and-suspenders — no secrets currently exist) -------------
.env
.env.*
*.key
*.pem
credentials.json
secrets.*
