# =============================================================================
# N.O.V.A. — .gitattributes
# Normalize line endings to LF on commit; prevent cross-OS CRLF churn.
# =============================================================================

# Default: detect text/binary automatically, enforce LF on commit.
* text=auto eol=lf

# Explicit text files — always LF, never auto-detected as binary.
*.py       text eol=lf
*.pyi      text eol=lf
*.toml     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.cfg      text eol=lf
*.ini      text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.python-version text eol=lf
*.lock     text eol=lf

# Windows-specific shipped scripts use CRLF (setup.bat lands in Story 2.1).
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary files — never munge.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.db       binary
*.sqlite   binary
*.sqlite3  binary
